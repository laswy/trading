# Execution (lower slippage cost)
SLIPPAGE_PCT=8
SLIPPAGE_NEW_PCT=25
SLIPPAGE_MID_PCT=12
PRIORITY_FEE_DEFAULT=100000
PRIORITY_FEE_HIGH=450000
PRIORITY_FEE_VERY_HIGH=900000

# Risk and profit taking
TAKE_PROFIT_PCT=35
TRAIL_TRIGGER_PCT=22
