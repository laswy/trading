# Profile A: EARLY_SNIPER (<5p aggressive)
# Use for very new tokens, faster reaction, higher fill probability.
# Keep your secret keys (wallet/API/telegram) in .env; this file only overrides strategy knobs.

MIN_OPPORTUNITY_SCORE=72
SCAN_INTERVAL_SECONDS=2
VALIDATOR_WORKERS=24

# Entry / Exit cadence
TP_CHECK_NEW_S=1
TP_CHECK_MID_S=3
TP_CHECK_OLD_S=8

# Execution (higher fill probability)
SLIPPAGE_PCT=12
SLIPPAGE_NEW_PCT=35
SLIPPAGE_MID_PCT=18
PRIORITY_FEE_DEFAULT=150000
PRIORITY_FEE_HIGH=650000
PRIORITY_FEE_VERY_HIGH=1200000

# Risk and profit taking
TAKE_PROFIT_PCT=28
TRAIL_TRIGGER_PCT=18
TRAIL_TARGET_PCT=28
FAST_DUMP_PCT=-12
FAST_DUMP_WINDOW_S=8

RISK_MAX_POSITIONS=4
RISK_MAX_DAILY_TRADES=25
RISK_MAX_DAILY_LOSS=40
